# ── Langfuse ─────────────────────────────────────────────────────────────────
# These values are for LOCAL development only. Do not use in production.

# Langfuse server
NEXTAUTH_URL=http://localhost:3100
NEXTAUTH_SECRET=my-local-langfuse-secret
SALT=my-local-langfuse-salt
TELEMETRY_ENABLED=false

# Langfuse Postgres (separate from the app database)
LANGFUSE_POSTGRES_USER=langfuse
LANGFUSE_POSTGRES_PASSWORD=langfuse
LANGFUSE_POSTGRES_DB=langfuse
LANGFUSE_POSTGRES_PORT=5433
DATABASE_URL=postgresql://langfuse:langfuse@langfuse-postgres:5432/langfuse

# Langfuse default project API keys (auto-created on first boot)
# Use these in your backend .env to send traces to Langfuse.
LANGFUSE_INIT_ORG_ID=my-org
LANGFUSE_INIT_ORG_NAME=HabitTracker
LANGFUSE_INIT_PROJECT_ID=my-project
LANGFUSE_INIT_PROJECT_NAME=HabitTracker-Local
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=lf-pk-local-dev
LANGFUSE_INIT_PROJECT_SECRET_KEY=lf-sk-local-dev
LANGFUSE_INIT_USER_EMAIL=admin@local.dev
LANGFUSE_INIT_USER_NAME=Admin
LANGFUSE_INIT_USER_PASSWORD=admin123
