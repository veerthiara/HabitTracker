# ──────────────────────────────────────────────────
# Environment variable template — copy to .env.production
# (or .env.development for machine-specific local overrides)
# ──────────────────────────────────────────────────

# Full base URL the browser will use for API calls.
# Local dev:  http://127.0.0.1:8000/api  (or /api if using Vite proxy)
# Dev deploy: https://dev.yourapp.com/api
# Prod:       https://api.yourapp.com/api
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# Backend origin — used only by the Vite dev-server proxy (no effect in prod builds).
VITE_BACKEND_ORIGIN=http://127.0.0.1:8000
