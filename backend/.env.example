# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_TIMEOUT_SEC=60
OLLAMA_CHAT_TIMEOUT_SEC=120
OLLAMA_MAX_RETRIES=3
OLLAMA_RETRY_BACKOFF_SEC=1

# ── Embedding pipeline ───────────────────────────────────────────────────────
EMBED_BATCH_SIZE=50
EMBED_EXPECTED_DIMS=768

# ── Conversation memory ──────────────────────────────────────────────────────
CONVERSATION_WINDOW=10

# ── Langfuse observability (optional) ────────────────────────────────────────
# Set all three to enable tracing. Get keys from Langfuse → Settings → API Keys.
# For a local Langfuse server: http://localhost:3000
# For Langfuse Cloud: https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3000
LANGFUSE_TRACING_ENABLED=true
